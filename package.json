{
  "name": "policy-engine-pdp",
  "version": "0.1.0",
  "private": true,
  "description": "PDP wrapper with context builder and OPA policy engine adapter",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:pdp:allow": "curl -s -X POST http://localhost:3000/pdp/evaluate -H 'Content-Type: application/json' --data-binary @requests/pdp/allow-evidence.json",
    "test:pdp:deny": "curl -s -X POST http://localhost:3000/pdp/evaluate -H 'Content-Type: application/json' --data-binary @requests/pdp/deny-high-risk-evidence.json",
    "test:opa": "docker run --rm -v \"$PWD/opa:/work:ro\" openpolicyagent/opa:1.18.2 test /work/policies /work/data"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-fastify": "^11.1.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
